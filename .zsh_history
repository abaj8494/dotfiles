  if (unlinkFinderConfig["Minimum Characters"]) {¥
    minimumPageLength = parseInt(unlinkFinderConfig["Minimum Characters"]);¥
  } else {¥
    minimumPageLength = 2;¥
  }¥
  if (unlinkFinderConfig["Alias Case-Sensitive"] == "Y") {¥
    aliasCaseSensitive = true;¥
  } else {¥
    aliasCaseSensitive = false;¥
  }¥
